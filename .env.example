# etsy-oracle — environment variable contract
# Copy this to .env and fill in your values. Never commit .env.

# ── Etsy API ──────────────────────────────────────────────────────────────────
# Your Etsy developer app keystring (API key).
# Obtain at: https://www.etsy.com/developers/your-apps
# Required for all API calls. Used as the x-api-key header.
ETSY_API_KEYSTRING=

# Your Etsy developer app shared secret.
# Only required if you later add OAuth2 flows (not needed for v1 read-only use).
ETSY_SHARED_SECRET=

# ── Rate limiter ──────────────────────────────────────────────────────────────
# Daily request budget (Etsy allows 10,000/day per key). Default: 10000.
# Lower this if you share the key across multiple processes.
ETSY_DAILY_REQUEST_LIMIT=10000

# Minimum milliseconds between requests (default: 100ms = 10 req/s burst ceiling).
ETSY_MIN_REQUEST_INTERVAL_MS=100

# ── DuckDB ────────────────────────────────────────────────────────────────────
# Path to the DuckDB database file (absolute or relative to the repo root).
DUCKDB_PATH=./data/etsy-oracle.duckdb

# ── Worker ────────────────────────────────────────────────────────────────────
# Worker log level: debug | info | warn | error
LOG_LEVEL=info
